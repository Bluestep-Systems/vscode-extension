{
  "name": "bsjs-push-pull-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace root for B6P core, CLI, and VS Code extension",
  "license": "MIT",
  "workspaces": [
    "packages/b6p-core",
    "packages/b6p-cli",
    "packages/b6p-vscode"
  ],
  "scripts": {
    "compile": "npm run compile -w @bluestep-systems/b6p-core && npm run compile -w @bluestep-systems/b6p-cli && npm run compile -w bsjs-push-pull",
    "watch": "npm-run-all -p watch:*",
    "watch:core": "npm run watch -w @bluestep-systems/b6p-core",
    "watch:cli": "npm run watch -w @bluestep-systems/b6p-cli",
    "watch:vscode": "npm run watch -w bsjs-push-pull",
    "lint": "eslint packages/*/src",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format-check": "prettier --check \"packages/*/src/**/*.ts\"",
    "check-types": "npm run check-types -w @bluestep-systems/b6p-core && npm run check-types -w @bluestep-systems/b6p-cli && npm run check-types -w bsjs-push-pull",
    "test": "npm run test -w bsjs-push-pull",
    "tests": "npm run test",
    "clean": "npm run clean -ws --if-present && rm -rf node_modules/.cache",
    "package-extension": "npm run package-extension -w bsjs-push-pull",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "eslint": "^9.34.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.0",
    "typescript": "^5.9.2"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
